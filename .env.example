# Qpedia runtime configuration. Copy to .env and fill in.

# --- LLM provider ---
# Auto-detected from whichever API key is set. Set QPEDIA_LLM_PROVIDER explicitly
# to override the auto-detection.
#   anthropic         (Anthropic direct — MVP default)
#   openai            (OpenAI direct)
#   openrouter        (OpenRouter — multi-model aggregator)
#   openai-compatible (vLLM / Ollama / LM Studio / on-prem)
# QPEDIA_LLM_PROVIDER=anthropic

# Override the per-provider default model.
#   anthropic default  : claude-haiku-4-5
#   openai default     : gpt-4.1-mini
#   openrouter default : anthropic/claude-haiku-4-5
# QPEDIA_LLM_MODEL=claude-opus-4-7

# Anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional override (proxy etc.)

# OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1      # optional override

# OpenRouter
# OPENROUTER_API_KEY=

# OpenAI-compatible (vLLM / Ollama / LM Studio — on-prem)
# QPEDIA_LLM_BASE_URL=http://vllm:8000/v1
# QPEDIA_LLM_API_KEY=

# --- Storage ---
# Postgres password — single source of truth. Both the postgres service
# and the app's DB URL (constructed in docker-compose.yml) read it.
QPEDIA_DB_PASSWORD=qpedia-dev
QPEDIA_WIKI_AUTHOR_NAME=qpedia-bot
QPEDIA_WIKI_AUTHOR_EMAIL=bot@qpedia.local

# QPEDIA_DATA_DIR and QPEDIA_DB_URL below are ONLY used for a host-side
# `cargo run -p qpedia-api` (the binary auto-loads this .env via dotenvy).
# Under Docker Compose they're ignored: the Dockerfile pins QPEDIA_DATA_DIR
# to /data and docker-compose.yml builds QPEDIA_DB_URL pointing at the
# `postgres` service. So you can keep these at their localhost values and
# both `docker compose up` and `cargo run` work from the same file.
#
# Bring up just the DB for local runs:  docker compose up -d postgres
QPEDIA_DATA_DIR=./data
QPEDIA_DB_URL=postgres://qpedia_admin:qpedia-dev@127.0.0.1:5432/qpedia?sslmode=disable

# --- Optional: Marker high-fidelity PDF sidecar ---
# Start with: docker compose --profile marker up -d marker
# Then set this so the Rust PDF extractor delegates here (with
# pdfium as a fallback if the sidecar is unreachable).
# Required for scanned / image-only PDFs — without it, those PDFs
# will produce empty extracted text.
# QPEDIA_MARKER_URL=http://marker:8000

# Opt-in: route EVERY pdf through Marker first (high-fidelity markdown
# for table-heavy / multi-column / formula-heavy PDFs). Falls back to
# pdfium on sidecar error so a Marker outage doesn't block ingestion.
# Requires QPEDIA_MARKER_URL above. Costs minutes per PDF on CPU.
# QPEDIA_MARKER_PREFER=1

# --- Auth ---
# Default behavior (none of QPEDIA_OIDC_ISSUER or QPEDIA_FIREBASE_PROJECT_ID
# set): dev mode — every request is the synthetic `dev:admin` user with the
# `admin` group. QPEDIA_AUTH_MODE=dev forces dev regardless.

# v2 recommended: Firebase Auth federation. One project handles Google,
# Apple, Microsoft, GitHub, X (Twitter), Facebook, plus generic OIDC/SAML
# for enterprise SSO. Backend just verifies the ID token.
# QPEDIA_FIREBASE_PROJECT_ID=qpedia-acme
# Frontend also needs (build-time, VITE_-prefixed):
#   VITE_FIREBASE_API_KEY=...
#   VITE_FIREBASE_AUTH_DOMAIN=qpedia-acme.firebaseapp.com
#   VITE_FIREBASE_PROJECT_ID=qpedia-acme
#   VITE_FIREBASE_SSO_PROVIDER_ID=oidc.acme   (optional, enables SSO button)

# --- Connectors: Google Drive (SSO-aligned OAuth) ---
# One Google OAuth 2.0 client (Web application) backs the "Connect Google
# Drive" admin button. Create it at console.cloud.google.com -> APIs &
# Services -> Credentials, enable the Drive API, and register the redirect
# URI below as an authorized redirect. The authorization-code flow uses
# access_type=offline to obtain a durable refresh token stored in
# oauth_grants. (Firebase login handles identity; this is a separate,
# complementary consent for resource access.)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URL=http://127.0.0.1:8080/api/v1/connectors/google/callback

# Legacy v1: direct OIDC against a single IdP. Kept for in-place deployments.
# QPEDIA_OIDC_ISSUER=https://login.example.com
# QPEDIA_OIDC_CLIENT_ID=
# QPEDIA_OIDC_CLIENT_SECRET=
# QPEDIA_OIDC_REDIRECT_URL=http://127.0.0.1:8080/auth/callback
# QPEDIA_OIDC_GROUPS_CLAIM=groups
# QPEDIA_OIDC_END_SESSION_URL=https://login.example.com/oidc/logout

# --- Observability ---
RUST_LOG=qpedia=info,tower_http=info,axum=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Embedding ---
QPEDIA_EMBED_CACHE_DIR=/data/models

# --- HTTP ---
QPEDIA_BIND=0.0.0.0:8080

# --- Job runner pool ---
# Number of concurrent ingest workers spawned by qpedia-api. Each one
# polls `claim_next_job` independently; SKIP LOCKED guarantees two
# workers never claim the same job. Default 1; clamped to [1, 32].
# Bump on operators with bursty uploads or slow agent loops.
# QPEDIA_WORKERS=4

# --- Chat rate limit (per tenant, token bucket) ---
# Defaults: 30 requests / minute, burst of 10. Generous for interactive
# use, hostile to a runaway client. 429 with `Retry-After` once empty.
# In-process — fleet-wide effective limit is N * QPEDIA_CHAT_RPM across
# N qpedia-api replicas. qpedia-pvt overrides with a Redis-backed
# implementation via AppBuilder::with_chat_rate_limiter.
# QPEDIA_CHAT_RPM=30
# QPEDIA_CHAT_BURST=10
