# Qpedia runtime configuration. Copy to .env and fill in.

# --- LLM provider ---
# Auto-detected from whichever API key is set. Set QPEDIA_LLM_PROVIDER explicitly
# to override the auto-detection.
#   anthropic         (Anthropic direct — MVP default)
#   openai            (OpenAI direct)
#   openrouter        (OpenRouter — multi-model aggregator)
#   openai-compatible (vLLM / Ollama / LM Studio / on-prem)
# QPEDIA_LLM_PROVIDER=anthropic

# Override the per-provider default model.
#   anthropic default  : claude-haiku-4-5
#   openai default     : gpt-4.1-mini
#   openrouter default : anthropic/claude-haiku-4-5
# QPEDIA_LLM_MODEL=claude-opus-4-7

# Anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # optional override (proxy etc.)

# OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1      # optional override

# OpenRouter
# OPENROUTER_API_KEY=

# OpenAI-compatible (vLLM / Ollama / LM Studio — on-prem)
# QPEDIA_LLM_BASE_URL=http://vllm:8000/v1
# QPEDIA_LLM_API_KEY=

# --- Storage ---
QPEDIA_DATA_DIR=/data
# v2: Postgres + pgvector. Connect as qpedia_admin for migrations; the
# pool's runtime queries auto-switch to qpedia_app via SET LOCAL.
QPEDIA_DB_URL=postgres://qpedia_admin:qpedia-dev@postgres:5432/qpedia?sslmode=disable
QPEDIA_DB_PASSWORD=qpedia-dev
# Legacy paths — set only if running the migration tool against an old
# SQLite + Weaviate deployment.
# QPEDIA_LEGACY_SQLITE=/data/sqlite/qpedia.db
# QPEDIA_LEGACY_WEAVIATE_URL=http://weaviate:8080
QPEDIA_WIKI_AUTHOR_NAME=qpedia-bot
QPEDIA_WIKI_AUTHOR_EMAIL=bot@qpedia.local

# --- Optional: Marker high-fidelity PDF sidecar ---
# Start with: docker compose --profile marker up -d marker
# Then set this so the Rust PDF extractor delegates here (with
# pdfium as a fallback if the sidecar is unreachable).
# Required for scanned / image-only PDFs — without it, those PDFs
# will produce empty extracted text.
# QPEDIA_MARKER_URL=http://marker:8000

# --- Auth ---
# Default behavior (no QPEDIA_OIDC_ISSUER set): dev mode — every request
# is the synthetic `dev:admin` user with the `admin` group. Set the OIDC
# env vars to enable real authentication; QPEDIA_AUTH_MODE=dev forces dev.
# QPEDIA_AUTH_MODE=dev
# QPEDIA_OIDC_ISSUER=https://login.example.com
# QPEDIA_OIDC_CLIENT_ID=
# QPEDIA_OIDC_CLIENT_SECRET=
# QPEDIA_OIDC_REDIRECT_URL=http://127.0.0.1:8080/auth/callback
# QPEDIA_OIDC_GROUPS_CLAIM=groups
# QPEDIA_OIDC_END_SESSION_URL=https://login.example.com/oidc/logout

# --- Observability ---
RUST_LOG=qpedia=info,tower_http=info,axum=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Embedding ---
QPEDIA_EMBED_CACHE_DIR=/data/models

# --- HTTP ---
QPEDIA_BIND=0.0.0.0:8080
