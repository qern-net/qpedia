{
  "name": "@qern/qpedia-web",
  "version": "0.1.0",
  "description": "Qpedia OSS SvelteKit SPA + reusable Svelte component library. The same project builds the app served by qpedia-api and exposes its lib/ as a Svelte package consumed by qpedia-pvt's web-pvt overlay.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "svelte": "./dist/components/*",
      "default": "./dist/components/*"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./stores": {
      "types": "./dist/stores.svelte.d.ts",
      "svelte": "./dist/stores.svelte.js",
      "default": "./dist/stores.svelte.js"
    },
    "./firebase": {
      "types": "./dist/firebase.d.ts",
      "default": "./dist/firebase.js"
    },
    "./app.css": "./src/app.css"
  },
  "files": [
    "dist",
    "src/lib",
    "src/app.css",
    "!**/*.spec.*",
    "!**/*.test.*"
  ],
  "scripts": {
    "dev": "vite dev --host 127.0.0.1 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22",
    "publint": "^0.2.12",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "firebase": "^11.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.1.0"
  }
}
