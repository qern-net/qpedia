{
  "uid": "qpedia-anomalies-alerts",
  "title": "Anomalies & Alerts",
  "tags": ["qpedia", "observability", "alerts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": {
    "list": [
      {
        "name": "Telemetry dropped-record warnings",
        "datasource": { "type": "loki", "uid": "loki" },
        "enable": true,
        "iconColor": "orange",
        "target": {
          "expr": "{service_name=\"qpedia-api\"} |= \"dropped\" |~ \"(?i)telemetry|export\"",
          "refId": "Anno"
        }
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_server_request_duration_milliseconds_count, tenant)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_server_request_duration_milliseconds_count, tenant)",
          "refId": "tenant"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error-rate spike (% 5xx) — threshold alert",
      "description": "Threshold-based, not ML. Fires when the 5xx error rate breaches the operator-set threshold.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 5 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_request_duration_milliseconds_count{http_response_status_code=~\"5..\",tenant=~\"$tenant\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_milliseconds_count{tenant=~\"$tenant\"}[5m])), 1)",
          "legendFormat": "5xx error %"
        }
      ],
      "alert": {
        "name": "Error-rate spike (5xx > 5%)",
        "conditions": [
          {
            "type": "query",
            "evaluator": { "type": "gt", "params": [5] },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "avg", "params": [] }
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m",
        "frequency": "1m"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency SLO breach (p99 ms) — threshold alert",
      "description": "Threshold-based, not ML. Fires when request p99 latency breaches the SLO threshold.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1000 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_milliseconds_bucket{tenant=~\"$tenant\"}[5m])))",
          "legendFormat": "p99 latency"
        }
      ],
      "alert": {
        "name": "Latency SLO breach (p99 > 1000ms)",
        "conditions": [
          {
            "type": "query",
            "evaluator": { "type": "gt", "params": [1000] },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "avg", "params": [] }
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m",
        "frequency": "1m"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Job-failure spike (failures/5m) — threshold alert",
      "description": "Threshold-based, not ML. Fires when job failures over 5m breach the operator-set threshold.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 10 } ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(jobs_completed_total{outcome=\"failure\",tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "job failures (5m)"
        }
      ],
      "alert": {
        "name": "Job-failure spike (> 10 / 5m)",
        "conditions": [
          {
            "type": "query",
            "evaluator": { "type": "gt", "params": [10] },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "max", "params": [] }
          }
        ],
        "executionErrorState": "alerting",
        "noDataState": "no_data",
        "for": "5m",
        "frequency": "1m"
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Telemetry dropped-record warnings",
      "description": "The DropThrottle throttled dropped-record warning lines surfaced from Loki (annotated above). Threshold/throttle-driven, not ML.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"qpedia-api\"} |= \"dropped\" |~ \"(?i)telemetry|export\""
        }
      ]
    }
  ]
}
