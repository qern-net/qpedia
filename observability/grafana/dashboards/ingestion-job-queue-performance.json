{
  "uid": "qpedia-ingestion-job-queue",
  "title": "Ingestion & Job Queue Performance",
  "tags": ["qpedia", "observability", "jobs", "ingestion"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(jobs_completed_total, tenant)",
        "query": {
          "qryType": 1,
          "query": "label_values(jobs_completed_total, tenant)",
          "refId": "tenant"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Job throughput (jobs/min) by kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "jobs/min" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "60 * sum by (kind) (rate(jobs_completed_total{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Job failure counts by kind",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (kind) (increase(jobs_completed_total{outcome=\"failure\",tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{kind}} failures"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Queue depth over time by kind (jobs.queue.depth)",
      "description": "Current pending-job count sampled from the Postgres job queue and exported as the jobs.queue.depth gauge (labeled by kind, optionally tenant).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (kind) (jobs_queue_depth{tenant=~\"$tenant\"})",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Job duration p95 by kind",
      "description": "From Job_Span via Tempo span-metrics.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_name=~\"Job.*|job.*\"}[5m])))",
          "legendFormat": "p95 {{span_name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Pipeline stage transitions (from -> to)",
      "description": "Pipeline-stage child spans of Job_Span record source.status.from -> source.status.to; explore the waterfall in Trace Explorer.",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service",
              "tag": "service.name",
              "operator": "=",
              "scope": "resource",
              "value": ["qpedia-api"],
              "valueType": "string"
            },
            {
              "id": "stage",
              "tag": "source.status.to",
              "operator": "!=",
              "scope": "span",
              "value": [""],
              "valueType": "string"
            }
          ],
          "limit": 50
        }
      ]
    }
  ]
}
