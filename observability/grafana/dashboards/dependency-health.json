{
  "uid": "qpedia-dependency-health",
  "title": "Dependency Health",
  "tags": ["qpedia", "observability", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_server_request_duration_milliseconds_count, tenant)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_server_request_duration_milliseconds_count, tenant)",
          "refId": "tenant"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current dependency status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (dependency) (dependency_up)",
          "legendFormat": "{{dependency}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Per-dependency up/down timeline",
      "description": "dependency.up gauge (1 = up, 0 = down) over the dashboard time range, by dependency name.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (dependency) (dependency_up)",
          "legendFormat": "{{dependency}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Uptime % over range by dependency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * avg_over_time(dependency_up[$__interval])",
          "legendFormat": "{{dependency}}"
        }
      ]
    }
  ]
}
