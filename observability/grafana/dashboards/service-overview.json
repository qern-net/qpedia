{
  "uid": "qpedia-service-overview",
  "title": "Service Overview",
  "tags": ["qpedia", "observability", "http"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_server_request_duration_milliseconds_count, tenant)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_server_request_duration_milliseconds_count, tenant)",
          "refId": "tenant"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s) by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (http_route) (rate(http_server_request_duration_milliseconds_count{tenant=~\"$tenant\"}[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (% 5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_request_duration_milliseconds_count{http_response_status_code=~\"5..\",tenant=~\"$tenant\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_milliseconds_count{tenant=~\"$tenant\"}[5m])), 1)",
          "legendFormat": "5xx error %"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_server_request_duration_milliseconds_count{http_response_status_code=~\"4..\",tenant=~\"$tenant\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_milliseconds_count{tenant=~\"$tenant\"}[5m])), 1)",
          "legendFormat": "4xx error %"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request duration p50 / p95 / p99 by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, http_route) (rate(http_server_request_duration_milliseconds_bucket{tenant=~\"$tenant\"}[5m])))",
          "legendFormat": "p50 {{http_route}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_milliseconds_bucket{tenant=~\"$tenant\"}[5m])))",
          "legendFormat": "p95 {{http_route}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, http_route) (rate(http_server_request_duration_milliseconds_bucket{tenant=~\"$tenant\"}[5m])))",
          "legendFormat": "p99 {{http_route}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Dependency health summary",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (dependency) (dependency_up)",
          "legendFormat": "{{dependency}}",
          "instant": true
        }
      ]
    }
  ]
}
