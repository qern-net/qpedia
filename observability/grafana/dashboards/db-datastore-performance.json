{
  "uid": "qpedia-db-datastore-performance",
  "title": "DB / Datastore Performance",
  "tags": ["qpedia", "observability", "database"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_server_request_duration_milliseconds_count, tenant)",
        "query": {
          "qryType": 1,
          "query": "label_values(http_server_request_duration_milliseconds_count, tenant)",
          "refId": "tenant"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Datastore operation duration p50 / p95 / p99 by db.operation",
      "description": "Backed by Tempo span-metrics for Datastore_Span (db.system=postgresql). Quantiles over the span-metrics latency histogram grouped by the logical db.operation (span name).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_name=~\"db.*|Datastore.*\"}[5m])))",
          "legendFormat": "p50 {{span_name}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_name=~\"db.*|Datastore.*\"}[5m])))",
          "legendFormat": "p95 {{span_name}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_latency_bucket{span_name=~\"db.*|Datastore.*\"}[5m])))",
          "legendFormat": "p99 {{span_name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Datastore throughput (ops/s) by db.operation",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{span_name=~\"db.*|Datastore.*\"}[5m]))",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Datastore error breakdown by status",
      "description": "Span-metrics call rate filtered to error status; the Datastore_Span error category (connection / timeout / execution / authorization) is recorded on the span itself and visible in Trace Explorer.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (span_name, status_code) (rate(traces_spanmetrics_calls_total{span_name=~\"db.*|Datastore.*\",status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "legendFormat": "{{span_name}} {{status_code}}"
        }
      ]
    }
  ]
}
